FROM node:20.18.0

WORKDIR /app

# Instalar dependencias del sistema primero (si las hay)
# RUN apt-get update && apt-get install -y ...

# Configurar Corepack y pnpm
RUN corepack enable && \
    corepack prepare pnpm@latest --activate

# Copiar archivos de dependencias
COPY package.json pnpm-lock.yaml ./

# Instalar dependencias
RUN pnpm install --frozen-lockfile

# Copiar el resto del código
COPY . .

# Fix para bindings.sh (si existe)
RUN if [ -f bindings.sh ]; then \
      tr -d '\r' < bindings.sh > bindings.tmp && \
      mv bindings.tmp bindings.sh && \
      chmod +x bindings.sh; \
    fi

# Aumentar memoria para Node.js antes del build
ENV NODE_OPTIONS="--max-old-space-size=4096"

# Build de producción
RUN pnpm run build

# Puerto y variables de entorno
EXPOSE 5173
ENV NODE_ENV=production \
    RUNNING_IN_DOCKER=true

# Comando de inicio
CMD ["pnpm", "run", "dockerstart"]
