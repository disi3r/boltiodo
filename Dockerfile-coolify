FROM node:20.18.0

WORKDIR /app

# Solución definitiva: Instalar pnpm sin usar corepack
RUN npm install -g pnpm@8.15.7 && \
    pnpm -v && \
    npm install -g wrangler

# Copiar archivos de dependencias primero
COPY package.json pnpm-lock.yaml ./

# Instalar dependencias con pnpm instalado globalmente
RUN pnpm install --strict-peer-dependencies=false --frozen-lockfile

# Copiar el resto del código
COPY . .

# Fix para bindings.sh (si existe)
RUN if [ -f bindings.sh ]; then \
      tr -d '\r' < bindings.sh > bindings.tmp && \
      mv bindings.tmp bindings.sh && \
      chmod +x bindings.sh; \
    fi

# Aumentar memoria para Node.js antes del build
ENV NODE_OPTIONS="--max-old-space-size=4096"

# Build de producción
RUN pnpm run build

# Puerto y variables de entorno
EXPOSE 5173
ENV NODE_ENV=production \
    RUNNING_IN_DOCKER=true

# Comando de inicio
CMD ["pnpm", "run", "dockerstart"]
