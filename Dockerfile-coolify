FROM node:20.18.0

WORKDIR /app

# Solución para el error EEXIST - Instalación limpia de pnpm
RUN corepack enable && \
    corepack prepare pnpm@8.15.7 --activate && \
    npm install -g npm@latest && \
    npm install -g wrangler --force

# Copiar archivos de dependencias primero
COPY package.json pnpm-lock.yaml ./

# Instalación segura de dependencias
RUN pnpm install --strict-peer-dependencies=false --frozen-lockfile

# Copiar el resto del código
COPY . .

# Fix para bindings.sh (si existe)
RUN if [ -f bindings.sh ]; then \
      tr -d '\r' < bindings.sh > bindings.tmp && \
      mv bindings.tmp bindings.sh && \
      chmod +x bindings.sh; \
    fi

# Build de producción
RUN pnpm run build

# Puerto y variables de entorno
EXPOSE 5173
ENV NODE_ENV=production \
    RUNNING_IN_DOCKER=true

# Comando de inicio
CMD ["pnpm", "run", "dockerstart"]
